# BroBot Configuration
# Copy this to .env and fill in your values

# ═══ Database ═══
DB_URL=postgresql://node:password@localhost:5432/polyedge

# ═══ Polygon Wallet ═══
WALLET_ADDRESS=0xYourWalletAddress
POLYMARKET_PRIVATE_KEY=0xYourPrivateKeyHex
POLYGON_RPC_HTTP=https://your-rpc.quiknode.pro/your-key/
POLYGON_RPC_WSS=wss://your-rpc.quiknode.pro/your-key/

# ═══ Polymarket CLOB API ═══
CLOB_API_KEY=your-clob-api-key
CLOB_API_SECRET=your-clob-api-secret
CLOB_PASSPHRASE=your-clob-passphrase
CLOB_HOST=https://clob.polymarket.com

# ═══ Telegram Bot ═══
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ═══ Trading Settings ═══
TRADING_MODE=paper
# Options: paper (simulation) or live (real USDC)

# ═══ Anthropic AI (for research/chat features) ═══
ANTHROPIC_API_KEY=your-anthropic-key

# ═══ Bybit (for JC Copy Trader) ═══
BYBIT_API_KEY=your-bybit-key
BYBIT_API_SECRET=your-bybit-secret

# ═══ Discord (for Ghost/JC signal watcher) ═══
DISCORD_TOKEN=your-discord-user-token

# ═══ Brave Search (for research) ═══
BRAVE_SEARCH_API_KEY=your-brave-key

# ═══ Odds API (for sports) ═══
ODDS_API_KEY=your-odds-api-key
