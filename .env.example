# Database
DB_URL=postgresql://node@localhost/polyedge

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_key

# Polymarket (for live trading — leave empty for paper mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=1656605843

# Mode: 'paper' or 'live'
MODE=paper

# Risk params
MAX_POSITION_USD=50
MAX_POSITION_PCT=5.0
MIN_EDGE_AUTO_TRADE=0.25
MIN_EDGE_ALERT=0.15
CIRCUIT_BREAKER_DAILY_LOSS_PCT=10.0

# Scanning
METAR_SCAN_INTERVAL_MIN=30
MARKET_SCAN_INTERVAL_MIN=5
